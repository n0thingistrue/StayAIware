# ============================================================
# Daily Global Brief - Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual credentials.
# NEVER commit .env to version control.
# ============================================================

# --- Ollama cloud ---
# Créer une clé sur : https://ollama.com/settings/keys
OLLAMA_API_KEY=your-ollama-api-key-here
OLLAMA_MODEL=glm-5:cloud
OLLAMA_HOST=https://ollama.com

# --- Twilio WhatsApp ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Twilio sandbox number (format: whatsapp:+14155238886)
# For production, replace with your approved Twilio number
TWILIO_FROM_NUMBER=whatsapp:+14155238886

# Your personal WhatsApp number (include country code, e.g. +33612345678)
WHATSAPP_TO_NUMBER=whatsapp:+YOUR_PHONE_NUMBER

# --- Optional Settings ---

# Path to the feeds config file (default: feeds_config.json)
FEEDS_CONFIG_PATH=feeds_config.json

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO
